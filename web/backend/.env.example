# ── Core API Config ──────────────────────────────────────────────────────────
ENV=production
JWT_SECRET=generate_a_long_random_string_here
ENCRYPTION_KEY=your_32_byte_base64_encryption_key_here
MOBILE_APP_SECRET=eprohori-internal-2025

# ── Database ─────────────────────────────────────────────────────────────────
# Railway/Postgres URL: postgresql://user:pass@host:port/db
DATABASE_URL=sqlite:///./eprohori.db
REDIS_URL=redis://localhost:6379/0

# ── External AI Services ─────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_claude_api_key_here
VIRUSTOTAL_API_KEY=your_vt_api_key_here

# ── Notifications ─────────────────────────────────────────────────────────────
# Push Notifications (Firebase)
FCM_SERVER_KEY=your_firebase_server_key_here

# Email (Resend is primary, Brevo is fallback)
RESEND_API_KEY=re_xxxxxxxx
BREVO_API_KEY=xkeysib-xxxxxxxx
FROM_EMAIL=alerts@eprohori.tech
FROM_NAME=EProhori Safety

# ── Social & Support ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_LOGO_URL=https://eprohori.tech/logo.png
