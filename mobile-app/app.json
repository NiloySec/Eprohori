{
  "expo": {
    "name": "EProhori",
    "slug": "eprohori",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "eprohori",
    "updates": {
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD",
      "url": "https://u.expo.dev/eprohori-project"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.eprohori.app"
    },
    "android": {
      "package": "com.eprohori.app",
      "backgroundColor": "#1a0a1f",
      "permissions": [
        "android.permission.READ_PHONE_STATE",
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.READ_CALL_LOG",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "SEND",
          "data": [
            {
              "mimeType": "text/plain"
            }
          ],
          "category": [
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "eprohori"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        }
      ]
    },
    "extra": {
      "eas": {
        "projectId": "eprohori-project"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-updates",
      [
        "expo-notifications",
        {
          "color": "#1a0a1f",
          "sounds": []
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "EProhori শুধুমাত্র উচ্চ-ঝুঁকির প্রতারণা সনাক্ত হলে বা SOS চাপলে আপনার Guardian-কে আপনার লোকেশন পাঠানোর জন্য এই অনুমতি ব্যবহার করে।"
        }
      ]
    ]
  }
}
